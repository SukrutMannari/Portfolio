---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('journal')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const fmt = (d: Date) => d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' }).toUpperCase();
---

<BaseLayout title="Journal">
  <div class="page-head">
    <div class="label">// JOURNAL</div>
    <h1>Journal</h1>
    <p>What I'm building, playing, and learning — as it happens. The latest is always at the top.</p>
  </div>
  <section style="padding-top:24px">
    <div class="latest" style="grid-template-columns:repeat(3,1fr)">
      {
        posts.map((p) => (
          <a class="jcard" href={`/journal/${p.slug}`}>
            <div class="jimg" style={p.data.cover ? `background-image:url(${p.data.cover})` : ''}>
              {!p.data.cover && 'IMAGE · cover'}
            </div>
            <div class="jbody">
              <div class="jmeta">
                <span class={`jcat ${p.data.category}`}>{p.data.category}</span>
                <span class="jdate">{fmt(p.data.date)}</span>
              </div>
              <h3>{p.data.title}</h3>
              <p>{p.data.excerpt}</p>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
