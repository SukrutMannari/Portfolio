---
import { SITE, NAV } from '../data/site';
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<header>
  <div class="nav">
    <a class="brand" href="/">
      <div class="brand-avatar-wrap">
        <img src="/images/SukrutHeadshot.png" alt="Sukrut Mannari" class="brand-avatar" />
      </div>
      <div>
        <div class="brand-name">{SITE.name.toUpperCase()}</div>
        <div class="brand-sub">// {SITE.kicker}</div>
      </div>
    </a>
    <nav class="tabs">
      {
        NAV.map((item) => (
          <a
            class:list={[
              'tab',
              { active: isActive(item.href) && !item.resume && !item.admin },
              { resume: item.resume },
              { admin: item.admin },
            ]}
            href={item.href}
            title={item.admin ? 'Open content editor' : undefined}
          >
            {item.label.toUpperCase()}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<style>
  .brand-avatar-wrap {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    overflow: hidden;
    border: 1.5px solid var(--blue);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-sizing: border-box;
  }
  .brand-avatar {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transform: scale(1.1); /* Zoom in slightly on face */
    transform-origin: 50% 40%;
  }

  .tab.admin {
    color: var(--ink-dim);
    border: 1px dashed var(--line-soft);
    font-size: 11px;
    opacity: 0.7;
    margin-left: 6px;
  }
  .tab.admin:hover {
    color: var(--blue);
    border-color: var(--blue);
    opacity: 1;
    background: var(--paper-2);
  }
</style>
