---
import { SITE, NAV } from '../data/site';
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<header>
  <div class="nav">
    <a class="brand" href="/">
      <div class="logo">{SITE.initials}</div>
      <div>
        <div class="brand-name">{SITE.name.toUpperCase()}</div>
        <div class="brand-sub">// {SITE.kicker}</div>
      </div>
    </a>
    <nav class="tabs">
      {
        NAV.map((item) => (
          <a
            class:list={[
              'tab',
              { active: isActive(item.href) && !item.resume && !item.admin },
              { resume: item.resume },
              { admin: item.admin },
            ]}
            href={item.href}
            title={item.admin ? 'Open content editor' : undefined}
          >
            {item.label.toUpperCase()}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<style>
  .tab.admin {
    color: var(--ink-dim);
    border: 1px dashed var(--line-soft);
    font-size: 11px;
    opacity: 0.7;
    margin-left: 6px;
  }
  .tab.admin:hover {
    color: var(--blue);
    border-color: var(--blue);
    opacity: 1;
    background: var(--paper-2);
  }
</style>
