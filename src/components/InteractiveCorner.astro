---
// The Interactive Corner houses Sukrut's JavaScript/Canvas builds.
// Classic Snake is playable inline; the others link to the full /code tab.
---

<a class="seeall" href="/code">ALL APPS &amp; GAMES →</a>
<div class="label">Interactive Corner</div>
<div class="arcade">
  <aside class="arcade-list">
    <div class="sh">// APPS &amp; GAMES</div>
    <div class="appitem active" data-app="snake">Classic Snake <span class="pico">▶ play</span></div>
    <div class="appitem" data-app="astro">Astro Shooter <span class="pico">▶</span></div>
    <div class="appitem" data-app="tower">Tower Defense <span class="pico">▶</span></div>
    <div class="appitem" data-app="browser">Interstellar Browser <span class="pico">▶</span></div>
  </aside>
  <div class="arcade-stage">
    <div class="arcade-bar">
      <span class="gname" id="acName">Classic Snake</span>
      <span class="score" id="acScoreWrap">Score <b id="acScore">0</b></span>
      <button class="btn-mini" id="acStart">START</button>
    </div>
    <div class="arcade-canvas-wrap">
      <canvas id="snake" width="360" height="360"></canvas>
      <div id="acOverlay"></div>
    </div>
    <div class="dpad" id="acDpad">
      <button class="up" data-dir="0,-1" aria-label="up">↑</button>
      <button class="left" data-dir="-1,0" aria-label="left">←</button>
      <button class="down" data-dir="0,1" aria-label="down">↓</button>
      <button class="right" data-dir="1,0" aria-label="right">→</button>
    </div>
  </div>
</div>

<script>
  const canvas = document.getElementById('snake') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    const items = document.querySelectorAll<HTMLElement>('.appitem');
    const gname = document.getElementById('acName')!;
    const scoreEl = document.getElementById('acScore')!;
    const scoreWrap = document.getElementById('acScoreWrap') as HTMLElement;
    const startBtn = document.getElementById('acStart') as HTMLElement;
    const overlay = document.getElementById('acOverlay') as HTMLElement;
    const dpad = document.getElementById('acDpad') as HTMLElement;
    const GRID = 18;
    const CELL = canvas.width / GRID;
    let snake: { x: number; y: number }[], dir: any, nextDir: any, food: any, score = 0, loop: any, running = false, current = 'snake';

    const apps: Record<string, { name: string; playable: boolean; hint: string }> = {
      snake: { name: 'Classic Snake', playable: true, hint: 'Use WASD / Arrow keys (or the pad)' },
      astro: { name: 'Astro Shooter', playable: false, hint: 'WASD / Arrows + Space to shoot' },
      tower: { name: 'Tower Defense', playable: false, hint: 'Click to place turrets (cost 50 pts)' },
      browser: { name: 'Interstellar Browser', playable: false, hint: 'Client-side proxy browser interface' },
    };
    function rr(x: number, y: number, w: number, h: number) {
      ctx.beginPath();
      // @ts-ignore
      if (ctx.roundRect) ctx.roundRect(x, y, w, h, 3); else ctx.rect(x, y, w, h);
      ctx.fill();
    }
    function placeFood() {
      while (true) {
        const f = { x: (Math.random() * GRID) | 0, y: (Math.random() * GRID) | 0 };
        if (!snake.some((s) => s.x === f.x && s.y === f.y)) { food = f; return; }
      }
    }
    function reset() {
      snake = [{ x: 8, y: 9 }, { x: 7, y: 9 }, { x: 6, y: 9 }];
      dir = { x: 1, y: 0 }; nextDir = { x: 1, y: 0 }; score = 0; placeFood();
      scoreEl.textContent = '0'; draw();
    }
    function draw() {
      ctx.clearRect(0, 0, canvas!.width, canvas!.height);
      ctx.fillStyle = '#E8590C'; rr(food.x * CELL + 2, food.y * CELL + 2, CELL - 4, CELL - 4);
      snake.forEach((s, i) => { ctx.fillStyle = i === 0 ? '#155A95' : '#1C6FB5'; rr(s.x * CELL + 1, s.y * CELL + 1, CELL - 2, CELL - 2); });
    }
    function step() {
      dir = nextDir;
      const head = { x: snake[0].x + dir.x, y: snake[0].y + dir.y };
      if (head.x < 0 || head.x >= GRID || head.y < 0 || head.y >= GRID || snake.some((s) => s.x === head.x && s.y === head.y)) return gameOver();
      snake.unshift(head);
      if (head.x === food.x && head.y === food.y) { score += 10; scoreEl.textContent = String(score); placeFood(); } else snake.pop();
      draw();
    }
    function start() {
      if (current !== 'snake') return;
      reset(); running = true; startBtn.textContent = 'RESTART'; overlay.style.display = 'none';
      clearInterval(loop); loop = setInterval(step, 120);
    }
    function gameOver() {
      running = false; clearInterval(loop); startBtn.textContent = 'START'; overlay.style.display = 'grid';
      overlay.innerHTML = 'GAME OVER · Score ' + score + '<br><span style="font-size:11px;color:var(--ink-dim);font-weight:400">Press Start to play again</span>';
    }
    function setDir(x: number, y: number) { if (!running) return; if (x === -dir.x && y === -dir.y) return; nextDir = { x, y }; }
    document.addEventListener('keydown', (e) => {
      if (current !== 'snake' || !running) return;
      const k = e.key.toLowerCase();
      if (k === 'arrowup' || k === 'w') { setDir(0, -1); e.preventDefault(); }
      else if (k === 'arrowdown' || k === 's') { setDir(0, 1); e.preventDefault(); }
      else if (k === 'arrowleft' || k === 'a') { setDir(-1, 0); e.preventDefault(); }
      else if (k === 'arrowright' || k === 'd') { setDir(1, 0); e.preventDefault(); }
    });
    dpad.querySelectorAll<HTMLElement>('[data-dir]').forEach((b) =>
      b.addEventListener('click', () => { const p = b.getAttribute('data-dir')!.split(',').map(Number); setDir(p[0], p[1]); })
    );
    startBtn.addEventListener('click', start);
    items.forEach((it) =>
      it.addEventListener('click', () => {
        items.forEach((x) => x.classList.remove('active'));
        it.classList.add('active');
        current = it.getAttribute('data-app')!;
        const a = apps[current];
        gname.textContent = a.name; running = false; clearInterval(loop);
        if (a.playable) {
          scoreWrap.style.display = ''; startBtn.style.display = ''; startBtn.textContent = 'START';
          canvas!.style.display = ''; dpad.style.display = ''; reset(); overlay.style.display = 'grid';
          overlay.innerHTML = '▶ ' + a.hint + '<br><span style="font-size:11px;color:var(--ink-dim);font-weight:400">Press Start</span>';
        } else {
          scoreWrap.style.display = 'none'; startBtn.style.display = 'none'; canvas!.style.display = 'none'; dpad.style.display = 'none';
          overlay.style.display = 'grid';
          overlay.innerHTML = '<strong>' + a.name + '</strong><br><span style="font-size:12px;color:var(--ink-dim);font-weight:400">' + a.hint + '</span><br><br><span style="color:var(--blue);font-size:12px;font-weight:400">▶ Playable in the Code &amp; Games tab</span>';
        }
      })
    );
    reset();
    overlay.style.display = 'grid';
    overlay.innerHTML = '▶ Use WASD / Arrow keys (or the pad)<br><span style="font-size:11px;color:var(--ink-dim);font-weight:400">Press Start</span>';
  }
</script>
